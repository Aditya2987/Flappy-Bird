# GEMINI_API_KEY: Required for Gemini AI API calls.
# This is a placeholder key.
# AI Studio automatically injects this at runtime from user secrets.
# Users configure this via the Secrets panel in the AI Studio UI.
GEMINI_API_KEY=MY_GEMINI_API_KEY

# FIREBASE_API_KEY: Web/Android Client API Key from your Firebase project settings.
FIREBASE_API_KEY=YOUR_FIREBASE_API_KEY

# FIREBASE_PROJECT_ID: The unique Project ID of your Firebase project.
FIREBASE_PROJECT_ID=YOUR_FIREBASE_PROJECT_ID

# FIREBASE_APP_ID: The mobile application ID (e.g., 1:123456:android:abcdef) of your Android app.
FIREBASE_APP_ID=YOUR_FIREBASE_APP_ID

